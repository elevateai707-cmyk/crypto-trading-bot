# ─── Nous Research / Hermes API (REQUIRED) ─────────────────────────────────
NOUS_API_KEY=your_nous_api_key_here
# NOUS_API_BASE=https://inference-api.nousresearch.com/v1

# LLM Model Selection (optional — defaults below are fine-tuned for this bot)
# FAST_MODEL=deepseek/deepseek-v4-flash
# HEAVY_MODEL=Hermes-4-405B

# ─── Tavily AI Search API (REQUIRED for agent research capability) ──────────
# Get a free API key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Coinbase Advanced Trade API (REQUIRED for live trading) ────────────────
# Generate API keys from: https://advanced-trade.coinbase.com
# Permissions needed: View + Trade
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ─── Trading Parameters (optional defaults below) ──────────────────────────
# TRADING_PAIR=BTC-USD
# ORDER_SIZE_USD=50.0
# LOOP_INTERVAL_MINUTES=5
# RISK_PER_TRADE_PCT=2.0
# TRAILING_STOP_PCT=3.0
# HARD_STOP_PCT=2.0

# ─── Safety ─────────────────────────────────────────────────────────────────
# Set to False to enable real Coinbase trading
PAPER_TRADING=True

# ─── Dashboard ──────────────────────────────────────────────────────────────
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8050
# DASHBOARD_THEME=darkly